{
  "name": "shortcircuit",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" --if-present dev",
    "build": "pnpm -r --filter \"./apps/*\" --if-present build",
    "test": "pnpm -r --filter \"./apps/*\" --if-present test",
    "lint": "pnpm -r --filter \"./apps/*\" --if-present lint",
    "lint:fix": "pnpm -r --filter \"./apps/*\" --if-present lint:fix",
    "lint:fix:unsafe": "pnpm -r --filter \"./apps/*\" --if-present lint:fix:unsafe",
    "format": "biome format --write .",
    "check": "biome check .",
    "dev:web": "pnpm --filter @apps/web dev",
    "dev:backend": "pnpm --filter @apps/backend dev",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@types/node": "^20.14.11",
    "husky": "latest",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
